# clé d'API Google Gemini — utilisée pour la génération de texte (gemini-2.5-flash)
# et pour la génération d'images (Imagen 3 / Imagen 4 via la même clé)
GEMINI_API_KEY=AIza...

# upload Cloudinary pour rendre les images publiques (sinon Printful ne peut
# pas les récupérer). Format officiel Cloudinary, à copier depuis le dashboard.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# clé Printful pour le push catalogue (push-pod.js)
PRINTFUL_API_KEY=...
